{
  "name": "com.cianmm.calendar",
  "version": "1.0.0.0",
  "description": "Shows your next meeting and joins it from a single key.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "./scripts/build-helper.sh && rollup -c",
    "build:helper": "./scripts/build-helper.sh",
    "watch": "rollup -c -w",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "author": "Cian Mac Mahon",
  "license": "UNLICENSED",
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^22.18.10",
    "rollup": "^4.52.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
